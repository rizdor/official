---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="メンバー情報">
  <main class="container">

    <section class="chart-section">
      <h2>男女比</h2>
      <canvas id="genderChart"></canvas>
    </section>

    <section class="chart-section">
      <h2>出身大学</h2>
      <canvas id="univChart"></canvas>
    </section>

  </main>

  <!-- Chart.js（ブラウザ側で読み込む） -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js" client:load></script>

  <!-- グラフのアニメーション制御（ブラウザのみ） -->
  <script client:load>
    // -----------------------------
    // ① グラフ設定（アニメーションは一旦OFF）
    // -----------------------------
    const genderConfig = {
      type: "pie",
      data: {
        labels: ["男性", "女性"],
        datasets: [{
          data: [20, 25],
          backgroundColor: ["#4C8BF5", "#F56C9C"],
        }],
      },
      options: {
        animation: false, // ←最初はアニメーションなしで生成
        plugins: { legend: { position: "bottom" } },
      }
    };

    const univConfig = {
      type: "doughnut",
      data: {
        labels: ["早稲田", "慶應", "日本女子大", "立教", "その他"],
        datasets: [{
          data: [18, 10, 5, 4, 8],
          backgroundColor: [
            "#1E90FF", "#FF7F50", "#FFD700",
            "#7B68EE", "#3CB371"
          ],
        }],
      },
      options: {
        animation: false,
        plugins: { legend: { position: "bottom" } },
      }
    };


    // -----------------------------
    // ② Canvas を取得
    // -----------------------------
    const genderCanvas = document.getElementById("genderChart");
    const univCanvas = document.getElementById("univChart");

    // Chart インスタンスをあらかじめ生成
    const genderChart = new Chart(genderCanvas, genderConfig);
    const univChart = new Chart(univCanvas, univConfig);


    // -----------------------------
    // ③ IntersectionObserver で可視時にアニメーション実行
    // -----------------------------
    const animateChart = (chart, config) => {
      chart.options.animation = {
        animateRotate: true,
        animateScale: true,
        duration: 1800,
        easing: "easeOutCubic",
      };
      chart.update();
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (entry.target.id === "genderChart") {
              animateChart(genderChart, genderConfig);
            }
            if (entry.target.id === "univChart") {
              animateChart(univChart, univConfig);
            }
            // １回だけ発火
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 } // 画面の50%見えたら開始
    );

    observer.observe(genderCanvas);
    observer.observe(univCanvas);
  </script>
</Layout>
