<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>メンバー情報 | アンサンブル・リドール</title>
    <link rel="stylesheet" href="members.css" />

    <!-- Chart.js（公式CDN） -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>

  <body>
    <header class="header">
      <h1>メンバー情報</h1>
    </header>

    <main class="container">
      <!-- 男女比 -->
      <section class="chart-section">
        <h2>男女比（Animated）</h2>
        <div class="chart-box">
          <canvas id="genderChart"></canvas>
        </div>
      </section>

      <!-- 出身大学 -->
      <section class="chart-section">
        <h2>出身大学（Animated）</h2>
        <div class="chart-box">
          <canvas id="univChart"></canvas>
        </div>
      </section>
    </main>

    <script>
      /** ---------------------------
       * 男女比グラフ（Pie Chart）
       * -------------------------- */
      const genderConfig = {
        type: "pie",
        data: {
          labels: ["男性", "女性"],
          datasets: [
            {
              data: [20, 25],
              backgroundColor: ["#4C8BF5", "#F56C9C"],
            },
          ],
        },
        options: {
          responsive: true,
          animation: {
            animateRotate: true,  // 回転アニメーション
            animateScale: true,   // 拡大縮小アニメーション
            duration: 2000,
            easing: "easeOutBounce",
          },
          plugins: {
            legend: {
              position: "bottom",
            },
          },
        },
      };

      new Chart(document.getElementById("genderChart"), genderConfig);

      /** ---------------------------
       * 出身大学（Doughnut Chart）
       * -------------------------- */
      const univConfig = {
        type: "doughnut",
        data: {
          labels: ["早稲田大学", "慶應義塾大学", "日本女子大", "立教大", "その他"],
          datasets: [
            {
              data: [18, 10, 5, 4, 8],
              backgroundColor: [
                "#1E90FF",
                "#FF7F50",
                "#FFD700",
                "#7B68EE",
                "#3CB371",
              ],
            },
          ],
        },
        options: {
          responsive: true,
          animation: {
            animateRotate: true,
            animateScale: true,
            duration: 2500,
            easing: "easeInOutQuart",
          },
          plugins: {
            legend: {
              position: "bottom",
            },
          },
        },
      };

      new Chart(document.getElementById("univChart"), univConfig);
    </script>
  </body>
</html>
