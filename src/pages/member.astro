---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="メンバー情報">
  <main class="container">

    <section class="chart-section">
      <h2>男女比</h2>
      <canvas id="genderChart"></canvas>
    </section>

    <section class="chart-section">
      <h2>出身大学</h2>
      <canvas id="univChart"></canvas>
    </section>

  </main>

  <!-- Chart.js を CDN からロード（is:inline が必要） -->
  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/chart.js"
  ></script>

  <!-- グラフ描画スクリプト -->
  <script is:inline>
    // -----------------------------
    // ① アニメーションOFFで生成
    // -----------------------------
    const genderConfig = {
      type: "pie",
      data: {
        labels: ["男性", "女性"],
        datasets: [{
          data: [20, 25],
          backgroundColor: ["#4C8BF5", "#F56C9C"],
        }],
      },
      options: {
        animation: false,
        plugins: { legend: { position: "bottom" } },
      }
    };

    const univConfig = {
      type: "doughnut",
      data: {
        labels: ["早稲田", "慶應", "日本女子大", "立教", "その他"],
        datasets: [{
          data: [18, 10, 5, 4, 8],
          backgroundColor: [
            "#1E90FF", "#FF7F50", "#FFD700",
            "#7B68EE", "#3CB371"
          ],
        }],
      },
      options: {
        animation: false,
        plugins: { legend: { position: "bottom" } },
      }
    };

    // -----------------------------
    // ② Canvas を取得 → チャート生成
    // -----------------------------
    const genderCanvas = document.getElementById("genderChart");
    const univCanvas = document.getElementById("univChart");

    const genderChart = new Chart(genderCanvas, genderConfig);
    const univChart = new Chart(univCanvas, univConfig);

    // -----------------------------
    // ③ スクロールしたらアニメーション実行
    // -----------------------------
    const animateChart = (chart) => {
      chart.options.animation = {
        animateRotate: true,
        animateScale: true,
        duration: 1800,
        easing: "easeOutCubic",
      };
      chart.update();
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (entry.target.id === "genderChart") {
              animateChart(genderChart);
            }
            if (entry.target.id === "univChart") {
              animateChart(univChart);
            }
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );

    observer.observe(genderCanvas);
    observer.observe(univCanvas);
  </script>
</Layout>
